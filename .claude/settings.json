{
  "permissions": {
    "deny": [
      "Read(v3/index.html)",
      "Edit(v3/index.html)",
      "Write(v3/index.html)",
      "Read(package-lock.json)",
      "Read(app-v3/package-lock.json)",
      "Edit(package-lock.json)",
      "Edit(app-v3/package-lock.json)",
      "Read(app-v3/playwright-report/**)",
      "Read(app-v3/test-results/**)"
    ],
    "allow": [
      "Bash(npm run typecheck)",
      "Bash(npm run lint)",
      "Bash(npm run format:check)",
      "Bash(npm run test:v3)",
      "Bash(npm run build:v3)",
      "Bash(npm run test:e2e)",
      "Bash(npm run check)",
      "Bash(npm --prefix app-v3 ci)",
      "Bash(node tools/verify-single-file.mjs)",
      "Bash(git diff:*)",
      "Bash(git status)",
      "Bash(git log:*)",
      "Bash(git show:*)"
    ]
  }
}
